{
  "name": "@sellgar/kit",
  "type": "module",
  "version": "0.0.181",
  "description": "Sellgar kit",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./types/index.d.ts",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "fix": "eslint \"src/**/*.{ts,tsx}\" \"*.{ts,mjs}\" --fix && stylelint \"src/**/*.{css,scss}\" --custom-syntax postcss-scss --fix && prettier --write \"src/**/*.{md,ts,tsx,css,scss}\" \"*.{md,ts,mjs}\"",
    "login": "yarn npm login",
    "publish": "yarn npm publish"
  },
  "files": [
    "./dist/**/*",
    "./types/**/*"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./types/icons/index.d.ts",
      "import": "./dist/icons.js"
    },
    "./icons.css": "./dist/icons.css",
    "./inter.css": "./dist/inter.css",
    "./geologica.css": "./dist/geologica.css",
    "./theme.css": "./dist/theme.css",
    "./theme.mobile.css": "./dist/theme.mobile.css",
    "./theme.4k.desktop.css": "./dist/theme.4k.desktop.css",
    "./theme.full-hd.desktop.css": "./dist/theme.full-hd.desktop.css"
  },
  "dependencies": {
    "@floating-ui/dom": "1.7.6",
    "@floating-ui/react": "0.27.19",
    "@react-input/mask": "2.0.4",
    "@react-input/number-format": "2.0.3",
    "classnames": "2.5.1",
    "date-fns": "4.4.0",
    "moment": "2.30.1",
    "moment-timezone": "0.6.2",
    "react-slider": "2.0.6"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@storybook/react-vite": "10.4.6",
    "@types/react-slider": "1.3.6",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-dts": "5.0.3",
    "vite-plugin-lib-inject-css": "2.2.2",
    "vite-plugin-webfont-dl": "3.12.0"
  },
  "author": "",
  "license": "ISC",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
